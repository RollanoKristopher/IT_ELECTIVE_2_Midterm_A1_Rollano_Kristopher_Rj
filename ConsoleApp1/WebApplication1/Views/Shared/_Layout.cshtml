<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Portfolio - Kristopher Rollano</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <style>
            :root {
                --bg-dark: #0f172a;
                --sidebar-bg: #0b0f19;
                --card-bg: rgba(255, 255, 255, 0.05);
                --accent-blue: #3b82f6;
                --text-main: #f8fafc;
                --text-muted: #94a3b8;
            }

            body {
                font-family: 'Segoe UI', sans-serif;
                background: var(--bg-dark);
                color: var(--text-main);
                scroll-behavior: smooth;
            }

            /* Fixed Sidebar Navigation */
            .sidebar {
                width: 250px;
                height: 100vh;
                position: fixed;
                top: 0;
                left: 0;
                background: var(--sidebar-bg);
                border-right: 1px solid rgba(255, 255, 255, 0.1);
                z-index: 1000;
                padding: 20px 15px;
            }

                .sidebar h4 {
                    color: var(--text-main);
                    font-weight: 700;
                }

                .sidebar hr {
                    color: var(--text-muted);
                    opacity: 0.2;
                }

                .sidebar a {
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    padding: 12px 20px;
                    color: var(--text-muted);
                    text-decoration: none;
                    border-radius: 8px;
                    margin-bottom: 5px;
                    transition: all .3s ease;
                    font-weight: 500;
                }

                    .sidebar a:hover {
                        color: white;
                        background: rgba(59, 130, 246, 0.15);
                        transform: translateX(5px);
                    }

                    .sidebar a.active {
                        color: white;
                        background: rgba(59, 130, 246, 0.3);
                        font-weight: bold;
                        border-left: 4px solid var(--accent-blue);
                        border-radius: 0 8px 8px 0;
                        padding-left: 16px;
                    }

            /* Main Scrollable Content Area */
            .content {
                margin-left: 250px;
                padding: 60px 40px;
                min-height: 100vh;
            }

            /* 🪄 Fade-In Viewport Animations */
            .fade-in {
                opacity: 0;
                transform: translateY(30px);
                transition: all 0.6s ease;
            }

                .fade-in.show {
                    opacity: 1;
                    transform: translateY(0);
                }

            /* 💳 Modernized Uniform Cards */
            .card-modern {
                background: var(--card-bg);
                border: 1px solid rgba(255, 255, 255, 0.08);
                border-radius: 12px;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                backdrop-filter: blur(8px);
                color: var(--text-main);
                overflow: hidden;
            }

                .card-modern:hover {
                    transform: translateY(-8px);
                    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4);
                    border-color: rgba(59, 130, 246, 0.3);
                }

                .card-modern .card-body {
                    padding: 24px;
                }

                .card-modern h5, .card-modern h2 {
                    color: var(--text-main);
                }

                .card-modern p {
                    color: var(--text-muted);
                }

            /* 🔘 Modern Styled Buttons */
            .btn-modern {
                background: linear-gradient(135deg, #3b82f6, #6366f1);
                border: none;
                padding: 10px 24px;
                color: white;
                border-radius: 8px;
                font-weight: 500;
                transition: 0.3s ease;
                text-decoration: none;
                display: inline-block;
            }

                .btn-modern:hover {
                    transform: scale(1.05);
                    box-shadow: 0 0 20px rgba(99, 102, 241, 0.5);
                    color: white;
                }

            .btn-modern-outline {
                background: transparent;
                border: 1px solid rgba(255, 255, 255, 0.2);
                padding: 10px 24px;
                color: var(--text-main);
                border-radius: 8px;
                font-weight: 500;
                transition: 0.3s ease;
                text-decoration: none;
                display: inline-block;
            }

                .btn-modern-outline:hover {
                    background: rgba(255, 255, 255, 0.05);
                    border-color: var(--text-main);
                    color: white;
                }

            /* Section Spacing Helpers */
            .page-section {
                padding: 40px 0;
            }

            /* Profile Image Variant */
            .profile-img {
                border: 4px solid var(--accent-blue);
                box-shadow: 0 10px 30px rgba(59, 130, 246, 0.25);
                object-fit: cover;
            }

            /* Star Separators styling adjustments */
            hr.accent-hr {
                border-color: rgba(255, 255, 255, 0.15);
                opacity: 1;
            }

            .fa-star {
                color: var(--accent-blue);
            }
    </style>
</head>
<body>

   <!-- SIDEBAR -->
    <div id="sidebar" class="sidebar">
        <div class="p-2 mb-3 text-center">
            <img src="@Url.Content("~/images/profile/LOA.png")"
                 alt="Lyceum of Alabang Logo"
                 class="img-fluid mb-2"
                 style="max-height: 60px; object-fit: contain; filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));">

            <h5 class="m-0 text-white" style="font-size: 1rem;">Lyceum of Alabang</h5>
        </div>
       

        <hr />
        <a href="#home" class="nav-target active"><i class="fa-solid fa-house"></i> Home</a>
        <a href="#about" class="nav-target"><i class="fa-solid fa-user"></i> About</a>
        <a href="#skills" class="nav-target"><i class="fa-solid fa-brain"></i> Skills</a>
        <a href="#projects" class="nav-target"><i class="fa-solid fa-folder-open"></i> Projects</a>
        <a href="#contact" class="nav-target"><i class="fa-solid fa-address-book"></i> Contact</a>
    </div>
  

    <div class="content">
        @RenderBody()
    </div>

    <!-- Script to track viewport -->
    <script>
            document.addEventListener('DOMContentLoaded', () => {
                const sections = document.querySelectorAll('section');
                const navLinks = document.querySelectorAll('.sidebar a.nav-target');

                const observerOptions = {
                    root: null,
                    rootMargin: '-20% 0px -60% 0px',
                    threshold: 0
                };

                const sectionObserver = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            const currentId = entry.target.getAttribute('id');
                            navLinks.forEach(link => {
                                if (link.getAttribute('href') === `#${currentId}`) {
                                    link.classList.add('active');
                                } else {
                                    link.classList.remove('active');
                                }
                            });
                        }
                    });
                }, observerOptions);

                sections.forEach(section => sectionObserver.observe(section));
            });
    </script>

    <!-- Fade-in  -->
    <script>
            const elements = document.querySelectorAll('.fade-in');
            const elementObserver = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('show');
                    }
                });
            }, { threshold: 0.1 });

            elements.forEach(el => elementObserver.observe(el));
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>