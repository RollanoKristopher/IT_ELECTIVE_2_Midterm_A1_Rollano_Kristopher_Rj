<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Portfolio - Kristopher Rollano</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
   

    <style>
            :root {
                --bg-dark: #0f172a;
                --sidebar-bg: #0b0f19;
                --card-bg: rgba(255, 255, 255, 0.05);
                --accent-blue: #3b82f6;
                --text-main: #f8fafc;
                --text-muted: #94a3b8;
            }

            body {
                font-family: 'Segoe UI', sans-serif;
                background: var(--bg-dark);
                color: var(--text-main);
                scroll-behavior: smooth;
                display: flex;
                flex-direction: column;
                min-height: 100vh;
            }

            .footer {
                background: #0b1220;
                border-top: 1px solid rgba(255,255,255,.08);
                border-radius: 20px 20px 0 0;
                padding: 60px 40px 30px;
            }

            h2 {
                font-weight: 700;
                letter-spacing: 1px;
            }

            .page-section p {
                color: #cbd5e1;
            }
            

            /* Fixed Sidebar Navigation */
            .sidebar {
                width: 250px;
                height: 100vh;
                position: fixed;
                top: 0;
                left: 0;
                background: var(--sidebar-bg);
                border-right: 1px solid rgba(255, 255, 255, 0.1);
                z-index: 1000;
                padding: 20px 15px;
            }

                .sidebar h4 {
                    color: var(--text-main);
                    font-weight: 700;
                }

                .sidebar hr {
                    color: var(--text-muted);
                    opacity: 0.2;
                }

                .sidebar a {
                    display: flex;
                    align-items: center;
                    gap: 12px;
                    padding: 12px 20px;
                    color: var(--text-muted);
                    text-decoration: none;
                    border-radius: 8px;
                    margin-bottom: 5px;
                    transition: all .3s ease;
                    font-weight: 500;
                }

                    .sidebar a:hover {
                        color: white;
                        background: rgba(59, 130, 246, 0.15);
                        transform: translateX(5px);
                    }

                    .sidebar a.active {
                        color: white;
                        background: rgba(59, 130, 246, 0.3);
                        font-weight: bold;
                        border-left: 4px solid var(--accent-blue);
                        border-radius: 0 8px 8px 0;
                        padding-left: 16px;
                    }

            /* Main Scrollable Content Area */
            .content {
                margin-left: 250px;
                padding: 60px 40px;
                display: flex;
                flex-direction: column;
                min-height: 100vh;
            }

            /* 🪄 Fade-In Viewport Animations */
            .fade-in {
                opacity: 0;
                transform: translateY(30px);
                transition: all 0.6s ease;
            }

                .fade-in.show {
                    opacity: 1;
                    transform: translateY(0);
                }

            /* 💳 Modernized Uniform Cards */
            .card-modern {
                background: linear-gradient(145deg, #111827, #1e293b);
                border: 1px solid rgba(59,130,246,.18);
                border-radius: 18px;
                padding: 2rem;
                box-shadow: 0 12px 35px rgba(0,0,0,.35);
                transition: all .35s ease;
                overflow: hidden;
                position: relative;
            
                max-width: 1400px;
                margin: auto;
                }
            

                .card-modern::before {
                    content: "";
                    position: absolute;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 4px;
                    background: linear-gradient(90deg,#3b82f6,#60a5fa,#2563eb);
                }

                .card-modern:hover {
                    transform: translateY(-8px);
                    box-shadow: 0 18px 45px rgba(59,130,246,.20);
                    border-color: #3b82f6;
                }
            
            /* Skills Badges */
            .card-modern .badge {
                font-size: .85rem;
                padding: .55rem .85rem;
                border-radius: 20px;
                font-weight: 500;
            }

            /* Card Paragraphs */
            .card-modern p {
                color: var(--text-muted);
                min-height: 70px;
            }

            /* Responsive Layout */
            @@media (max-width:768px) {

                .sidebar {
                    position: relative;
                    width: 100%;
                    height: auto;
                }

                .content {
                    margin-left: 0;
                    padding: 30px 20px;
                }
               
            }

    </style>
</head>
<body>

   <!-- SIDEBAR -->
    @{
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }
    <div id="sidebar" class="sidebar">
        <div class="p-2 mb-3 text-center">
            <img src="@Url.Content("~/images/profile/LOA.png")"
                 alt="Lyceum of Alabang Logo"
                 class="img-fluid mb-2"
                 style="max-height: 60px; object-fit: contain; filter: drop-shadow(0 2px 8px rgba(0,0,0,0.5));">

            <h5 class="m-0 text-white" style="font-size: 1rem;">Lyceum of Alabang</h5>
        </div>
       

        <hr />
        <a asp-controller="Home"
           asp-action="Index"
           class="nav-target @(currentAction == "Index" ? "active" : "")">
            <i class="fa-solid fa-house"></i> Home
        </a>

        <a asp-controller="Home"
           asp-action="About"
           class="nav-target @(currentAction == "About" ? "active" : "")">
            <i class="fa-solid fa-user"></i> About
        </a>

        <a asp-controller="Home"
           asp-action="Skills"
           class="nav-target @(currentAction == "Skills" ? "active" : "")">
            <i class="fa-solid fa-brain"></i> Skills
        </a>

        <a asp-controller="Home"
           asp-action="Projects"
           class="nav-target @(currentAction == "Projects" ? "active" : "")">
            <i class="fa-solid fa-folder-open"></i> Projects
        </a>

        <a asp-controller="Home"
           asp-action="Contact"
           class="nav-target @(currentAction == "Contact" ? "active" : "")">
            <i class="fa-solid fa-address-book"></i> Contact
        </a>
    </div>

    <div class="content">
        @RenderBody()

        <partial name="footer" />
    </div>






 


    <!-- Script to track viewport -->
    <script>
            document.addEventListener("DOMContentLoaded", function () {

                const currentPath = window.location.pathname.toLowerCase();

                document.querySelectorAll(".sidebar a").forEach(link => {

                    link.classList.remove("active");

                    const href = link.getAttribute("href");

                    if (href && href.toLowerCase() === currentPath) {
                        link.classList.add("active");
                    }
                });

            });
    </script>

    <!-- Fade-in  -->
    <script>
            const elements = document.querySelectorAll('.fade-in');
            const elementObserver = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('show');
                    }
                });
            }, { threshold: 0.1 });

            elements.forEach(el => elementObserver.observe(el));
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>



</body>
</html>