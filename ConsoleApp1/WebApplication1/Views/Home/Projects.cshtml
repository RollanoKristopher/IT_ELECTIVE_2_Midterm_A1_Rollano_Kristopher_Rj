<h2 class="fw-bold mb-2">@ViewData["Title"]</h2>

<p class="mb-4">@ViewData["Description"]</p>
<!-- Project 1 -->

<div class="row g-4">
    <div class="col-md-4">
    <div class="card-modern h-100 d-flex flex-column justify-content-between">
        <div>
            <img src="@Url.Content("~/images/projects/Fizzbuzz.png")"
                 class="img-fluid w-100 card-img-top"
                 style="height: 180px; object-fit: contain; background: #1e293b; padding: 10px;"
                 alt="@ViewData["Project1Name"]">

            <div class="card-body pb-0">
                <h5 class="fw-bold">@ViewData["Project1Name"]</h5>

                <p class="small text-truncate-2 mt-2">
                    @ViewData["Project1Description"]
                </p>

                <p class="mt-2 mb-0">
                    <small class="text-white-50">
                        <strong>Tech Stack:</strong> @ViewData["Project1Tech"]
                    </small>
                </p>
            </div>
        </div>

        <div class="card-body pt-3">
            <a href="@ViewData["Project1Link"]"
               target="_blank"
               class="btn btn-sm btn-outline-primary w-100 text-truncate">
                <i class="fa-brands fa-github me-1"></i>View Repository
            </a>
        </div>
    </div>
</div>


